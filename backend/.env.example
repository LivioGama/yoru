# Yoru — backend environment template (self-host)
#
# Copy to backend/.env and adjust; docker-compose reads backend/.env:
#   cp backend/.env.example backend/.env
#
# The defaults below are a working ZERO-CLOUD self-host: SQLite on disk +
# local password auth, billing off, no external services. Every cloud section
# is OPTIONAL and ships KEYLESS — uncomment and fill a block in only if you
# opt into that provider. Never commit the filled copy.

# ── Core ──────────────────────────────────────────────────────────────────
# Session / event / hook-token store. SQLite by default (Docker path uses four
# slashes: sqlite:/// + absolute /app/data/receipt.db). Any Postgres URL works.
RECEIPT_DB_URL=sqlite:////app/data/receipt.db
# Environment label: development | production.
ENV=production
# Build identity stamped on GET /version.
RECEIPT_VERSION=0.1.0
# Public dashboard / CLI-callback domain, and the API's own URL.
RECEIPT_DOMAIN=localhost
API_URL=http://localhost:8002
# Public dashboard origin used for CLI pairing links. In split-host production,
# this is the UI origin, e.g. https://yoru.example.com while API_URL is
# https://api-yoru.example.com.
FRONTEND_ORIGIN=http://localhost:5173
# For split-host production, set a parent domain so the dashboard can read the
# non-HttpOnly CSRF cookie while the API still receives the HttpOnly session:
# COOKIE_DOMAIN=.example.com
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax
# Allowed browser origins for CORS — include scheme + port.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── Auth ──────────────────────────────────────────────────────────────────
# local (default) = users live in RECEIPT_DB_URL, scrypt + JWT, NO external
#   service. supabase = delegate to a Supabase GoTrue project (fill the
#   optional Supabase block below).
AUTH_PROVIDER=local
# Access-token signing secret. Leave unset to auto-generate a stable secret at
# backend/data/.auth_jwt_secret on first boot; set explicitly in production.
# AUTH_JWT_SECRET=
# Internet-exposed instance: require this token to run the first-run wizard.
# SETUP_TOKEN=

# ── Billing ───────────────────────────────────────────────────────────────
# Off for self-host: ingest is unlimited and no paywall surfaces appear.
BILLING_ENABLED=false

# ── Optional: Supabase (only when AUTH_PROVIDER=supabase) ──────────────────
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ── Optional: Email / SMTP ─────────────────────────────────────────────────
# With nothing set, welcome + notification mail are no-ops and the instance
# boots fine. Fill these to enable transactional email.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=

# ── Optional: ops toggles (defaults shown) ─────────────────────────────────
# LOG_LEVEL=INFO
# ENABLE_RATE_LIMITING=true
# ENABLE_TRACING=false
